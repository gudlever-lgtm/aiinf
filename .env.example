DB_HOST=localhost
DB_NAME=aiinf
DB_USER=dbuser
DB_PASS=dbpassword

# 32-byte key encoded as base64. Generate with:
#   php -r "echo base64_encode(random_bytes(32)), PHP_EOL;"
APP_ENCRYPTION_KEY=base64_32_byte_key_here

# Single admin account. Generate hash with:
#   php -r "echo password_hash('YOUR_PASSWORD', PASSWORD_BCRYPT), PHP_EOL;"
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=bcrypt_hash_here
